# Server Configuration
NODE_ENV=development
BACKEND_PORT=3001
FRONTEND_URL=http://localhost:5173

# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Supabase JWT secret used to verify access tokens locally in the auth
# middleware. Find it in Supabase dashboard: Project Settings → API → JWT
# Settings → "JWT Secret". When unset, the middleware falls back to calling
# supabase.auth.getUser() (one network round-trip per request).
SUPABASE_JWT_SECRET=your-jwt-secret-here

# API Keys (if needed)
# Add any API keys here
